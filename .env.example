# VoterPath India — Environment Variables
# Copy this file to .env and fill in your real keys
# DO NOT commit .env to Git

# Gemini AI (required for chat)
VITE_GEMINI_API_KEY=REPLACE_WITH_YOUR_KEY

# Google Translate API (Phase 3)
VITE_TRANSLATE_API_KEY=REPLACE_WITH_YOUR_KEY

# Google Calendar OAuth2 (Phase 3)
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID

# Firebase (Phase 3)
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_KEY
VITE_FIREBASE_AUTH_DOMAIN=voterpath-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=voterpath-india
VITE_FIREBASE_STORAGE_BUCKET=voterpath-india.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_ID

# App Config
VITE_APP_ENV=development
VITE_RATE_LIMIT_PER_MINUTE=10
